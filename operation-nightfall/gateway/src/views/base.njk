<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="NovaCorp Internal Developer Portal — Build, Deploy, Scale.">
  <title>{{ title }}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/static/css/style.css">
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🌑</text></svg>">
</head>
<body>
  <nav class="navbar">
    <div class="nav-container">
      <a href="/" class="nav-logo">
        <span class="logo-icon">◆</span>
        <span class="logo-text">NovaCorp</span>
        <span class="logo-badge">DevPortal</span>
      </a>
      <div class="nav-links">
        <a href="/" class="nav-link">Home</a>
        <a href="/status" class="nav-link">Status</a>
        <a href="/login" class="nav-link nav-link-primary">Sign In</a>
      </div>
    </div>
  </nav>

  <main class="main-content">
    {% if error %}
    <div class="alert alert-error">
      <span class="alert-icon">⚠</span>
      <span>{{ error }}</span>
    </div>
    {% endif %}

    {% block content %}{% endblock %}
  </main>

  <footer class="footer">
    <div class="footer-container">
      <p>&copy; {{ year }} NovaCorp Technologies Pvt. Ltd. Internal use only.</p>
      <p class="footer-version">DevPortal v3.2.1-rc4 &middot; API v1.8.0</p>
    </div>
  </footer>

  <script src="/static/js/main.js"></script>
</body>
</html>
